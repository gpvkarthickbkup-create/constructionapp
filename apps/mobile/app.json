{
  "expo": {
    "name": "Datalytics Construction",
    "slug": "datalytics-construction",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f26f31"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.datalytics.construction"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f26f31"
      },
      "package": "com.datalytics.construction"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Datalytics to access your photos for uploading site documents."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "de8864db-5c1d-4192-ae25-042a77862d78"
      }
    },
    "owner": "gpvkarthick"
  }
}
